---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<nav class="top-nav" aria-label="Primary">
  <a href="/get-started/install/">Get Started</a>
  <a href="/fundamentals/procedures/">Guide</a>
  <a href="/reference/smartdata-server/">Reference</a>
  <a
    href="https://smartdata-apis.netlify.app/nuget/v3/index.json"
    target="_blank"
    rel="noopener"
  >NuGet</a>
</nav>

<Default><slot /></Default>

<style>
  .top-nav {
    display: none;
    gap: 1rem;
    align-items: center;
    margin-inline-end: 0.5rem;
  }

  .top-nav a {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }

  .top-nav a:hover,
  .top-nav a:focus-visible {
    color: var(--sl-color-white);
  }

  @media (min-width: 50rem) {
    .top-nav {
      display: inline-flex;
    }
  }
</style>
