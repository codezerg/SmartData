@model UserEditViewModel

<div class="flex items-center gap-2 text-on-surface-variant text-xs font-bold mb-1">
    <span class="material-symbols-outlined text-[14px]">group</span>
    <span class="uppercase tracking-widest">System</span>
</div>
<div class="flex items-center justify-between mb-6">
    <h2 class="text-3xl font-extrabold text-on-surface tracking-tight">
        @(Model.IsNew ? "New User" : Model.Username)
    </h2>
    <a href="/@Routes.Prefix/users"
       hx-get="/@Routes.Prefix/users"
       hx-target="#content"
       hx-push-url="true"
       class="text-sm text-slate-500 hover:text-slate-700 flex items-center gap-1">
        <span class="material-symbols-outlined text-[16px]">arrow_back</span>
        Back to Users
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2.5 rounded-sm text-sm mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">error</span>
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-2.5 rounded-sm text-sm mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">check_circle</span>
        @Model.SuccessMessage
    </div>
}

<form hx-post="/@Routes.Prefix/users/@(Model.IsNew ? "new" : Model.Id)"
      hx-target="#content"
      hx-swap="innerHTML">

    <div class="bg-surface-container-lowest border border-outline-variant/20 p-5 mb-6">
        <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-4">Account</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4" style="max-width: 500px;">
            <div>
                <label class="block text-sm font-semibold text-on-surface mb-1">Username</label>
                <input type="text" name="username" value="@Model.Username" required
                       class="w-full bg-white border border-slate-200 rounded-sm py-1.5 px-3 text-sm focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-on-surface mb-1">
                    Password @(Model.IsNew ? "" : "(leave blank to keep)")
                </label>
                <input type="password" name="password" @(Model.IsNew ? "required" : "")
                       class="w-full bg-white border border-slate-200 rounded-sm py-1.5 px-3 text-sm focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none" />
            </div>
        </div>

        @if (!Model.IsNew)
        {
            <div class="mt-4">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="isDisabled" value="true" @(Model.IsDisabled ? "checked" : "")
                           class="w-4 h-4 rounded-sm border-slate-300 text-red-600 focus:ring-red-500" />
                    <span class="text-sm font-semibold text-on-surface">Disabled</span>
                    <span class="text-xs text-slate-400">(disabled users cannot log in)</span>
                </label>
            </div>

            <div class="mt-4 text-xs text-slate-400">
                <span class="font-semibold">ID:</span> @Model.Id
                &nbsp;&middot;&nbsp;
                <span class="font-semibold">Created:</span> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
            </div>
        }
    </div>

    <div class="bg-surface-container-lowest border border-outline-variant/20 p-5 mb-6">
        <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-4">Role</h3>

        <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="isAdmin" value="true" @(Model.IsAdmin ? "checked" : "")
                   id="isAdminToggle"
                   class="w-4 h-4 rounded-sm border-slate-300 text-primary focus:ring-primary" />
            <span class="text-sm font-semibold text-on-surface">Administrator</span>
            <span class="text-xs text-slate-400">(full access to all permissions)</span>
        </label>
    </div>

    <div class="bg-surface-container-lowest border border-outline-variant/20 p-5 mb-6" id="permissions-section">
        <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-4">Permissions</h3>

        <p class="text-xs text-slate-400 mb-4" id="admin-note" style="display: @(Model.IsAdmin ? "block" : "none")">
            Administrators have all permissions granted implicitly.
        </p>

        <div id="permissions-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" style="@(Model.IsAdmin ? "opacity: 0.4; pointer-events: none;" : "")">
            @foreach (var group in Model.AllPermissions)
            {
                <div class="border border-slate-100 rounded-sm p-3">
                    <h4 class="text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">@group.Category</h4>
                    @foreach (var entry in group.Entries)
                    {
                        <label class="flex items-center gap-2 py-0.5 cursor-pointer">
                            <input type="checkbox" name="permissions" value="@entry.Key"
                                   @(entry.Granted ? "checked" : "")
                                   class="w-3.5 h-3.5 rounded-sm border-slate-300 text-primary focus:ring-primary" />
                            <span class="text-sm text-on-surface">@entry.Name</span>
                            <span class="text-xs text-slate-400">@entry.Description</span>
                        </label>
                    }
                </div>
            }
        </div>
    </div>

    <div class="flex items-center gap-3">
        <button type="submit"
                class="bg-gradient-to-br from-primary to-primary-container text-white px-5 py-2 text-sm font-bold rounded-sm shadow-sm flex items-center gap-1 hover:opacity-90 transition-all">
            <span class="material-symbols-outlined text-[18px] mr-1">save</span>
            @(Model.IsNew ? "Create User" : "Save Changes")
        </button>
        <a href="/@Routes.Prefix/users"
           hx-get="/@Routes.Prefix/users"
           hx-target="#content"
           hx-push-url="true"
           class="px-5 py-2 text-sm font-semibold text-slate-500 hover:text-slate-700 transition-colors">
            Cancel
        </a>
    </div>
</form>

<script>
    document.getElementById('isAdminToggle')?.addEventListener('change', function () {
        const grid = document.getElementById('permissions-grid');
        const note = document.getElementById('admin-note');
        if (this.checked) {
            grid.style.opacity = '0.4';
            grid.style.pointerEvents = 'none';
            note.style.display = 'block';
        } else {
            grid.style.opacity = '1';
            grid.style.pointerEvents = 'auto';
            note.style.display = 'none';
        }
    });
</script>
