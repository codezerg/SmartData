@model UsersViewModel
<div id="users-table">
    <div class="bg-surface-container-lowest border border-outline-variant/20 overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-200">
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Username</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Role</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Status</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Last Login</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Created</th>
                    <th class="px-3 py-2"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                        <td class="px-3 py-2 font-semibold text-sm">
                            <a href="/@Routes.Prefix/users/@user.Id"
                               hx-get="/@Routes.Prefix/users/@user.Id"
                               hx-target="#content"
                               hx-push-url="true"
                               class="flex items-center text-primary hover:underline">
                                <span class="material-symbols-outlined text-[16px] mr-1 text-slate-400">person</span>
                                @user.Username
                            </a>
                        </td>
                        <td class="px-3 py-2 text-sm">
                            @if (user.IsAdmin)
                            {
                                <span class="inline-flex items-center gap-1 text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-sm">
                                    <span class="material-symbols-outlined text-[12px]">shield_person</span>
                                    Admin
                                </span>
                            }
                            else
                            {
                                <span class="text-xs text-slate-400">User</span>
                            }
                        </td>
                        <td class="px-3 py-2 text-sm">
                            @if (user.IsDisabled)
                            {
                                <span class="inline-flex items-center gap-1 text-xs font-semibold text-red-600 bg-red-50 px-2 py-0.5 rounded-sm">Disabled</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-sm">Enabled</span>
                            }
                        </td>
                        <td class="px-3 py-2 text-sm text-slate-400">@(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                        <td class="px-3 py-2 text-sm text-slate-400">@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-right px-3">
                            <div class="flex items-center justify-end gap-1">
                                <a href="/@Routes.Prefix/users/@user.Id"
                                   hx-get="/@Routes.Prefix/users/@user.Id"
                                   hx-target="#content"
                                   hx-push-url="true"
                                   class="text-slate-400 hover:text-primary transition-colors p-1 rounded-sm hover:bg-slate-100">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </a>
                                <button class="text-slate-400 hover:text-red-500 transition-colors p-1 rounded-sm hover:bg-red-50"
                                        hx-delete="/@Routes.Prefix/users/@user.Id"
                                        hx-target="#users-table"
                                        hx-swap="outerHTML"
                                        hx-confirm="Delete user '@user.Username'?">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
