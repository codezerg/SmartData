@model (string Type, string Icon, string Message)
@{
    var css = Model.Type switch
    {
        "error" => "bg-red-50 border border-red-200 text-red-700",
        "success" => "bg-green-50 border border-green-200 text-green-700",
        "warning" => "bg-amber-50 border border-amber-200 text-amber-700",
        "info" => "bg-indigo-50 border border-indigo-200 text-indigo-700",
        _ => "bg-slate-50 border border-slate-200 text-slate-700"
    };
}
<div class="@css px-4 py-3 rounded-sm text-sm flex items-center">
    <span class="material-symbols-outlined text-[18px] mr-2">@Model.Icon</span>
    @Model.Message
</div>
