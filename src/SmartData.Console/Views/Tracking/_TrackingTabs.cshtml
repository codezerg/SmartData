@model TrackingPageViewModel
@{
    var tabs = new List<(string Id, string Route, string Icon, string Label, bool Enabled)>
    {
        ("history", "history", "history", "History", Model.HistoryExists),
        ("ledger",  "ledger",  "link",    "Ledger",  Model.LedgerExists),
        ("verify",  "verify",  "verified","Verify",  Model.LedgerExists),
        ("digest",  "digest",  "download","Digest",  Model.LedgerExists),
        ("schema",  "schema",  "schema",  "Schema",  Model.HistoryExists || Model.LedgerExists),
    };
    var badgeClass = Model.Mode switch
    {
        "ledger" => "bg-emerald-100 text-emerald-800",
        "tracked" => "bg-sky-100 text-sky-800",
        _ => "bg-slate-100 text-slate-500",
    };
}
<div class="flex items-center gap-3 mb-4">
    <span class="inline-flex items-center text-xs font-bold uppercase tracking-wider px-2 py-0.5 rounded-full @badgeClass">@Model.Mode</span>
    <a class="text-sm text-slate-500 hover:text-indigo-500"
       hx-get="/@Routes.Prefix/db/@Model.Db/tables/@Model.Table"
       hx-target="#content" hx-push-url="true">← Back to @Model.Table</a>
</div>

<div class="flex gap-1 border-b border-slate-200 mb-6">
    @foreach (var tab in tabs)
    {
        var isActive = tab.Id == Model.ActiveTab;
        var disabledClass = tab.Enabled ? "" : " pointer-events-none opacity-40";
        var activeClass = isActive
            ? "text-indigo-600 border-indigo-600"
            : "text-slate-500 hover:text-indigo-500 border-transparent";
        <a class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold border-b-2 -mb-px cursor-pointer transition-colors @activeClass@disabledClass"
           hx-get="/@Routes.Prefix/db/@Model.Db/tables/@Model.Table/tracking/@tab.Route"
           hx-target="#content" hx-push-url="true">
            <span class="material-symbols-outlined text-[18px]">@tab.Icon</span>
            <span>@tab.Label</span>
        </a>
    }
</div>
