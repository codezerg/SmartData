@model DashboardViewModel
@{
    Layout = "_Layout";

    var metrics = Model.Metrics.Items;

    // Counters have multiple entries per tag combination — sum all with same name
    var totalRequests = metrics.Where(m => m.Name == "rpc.requests" && m.Type == "counter").Sum(m => m.Value);
    var totalErrors = metrics.Where(m => m.Name == "rpc.errors" && m.Type == "counter").Sum(m => m.Value);
    var errorRate = totalRequests > 0 ? totalErrors / totalRequests * 100 : 0;

    // Histograms: average the percentiles across tag variants (weighted by count)
    var rpcDurations = metrics.Where(m => m.Name == "rpc.duration_ms" && m.Type == "histogram").ToList();
    var totalCount = rpcDurations.Sum(m => m.Count ?? 0);
    var p50 = totalCount > 0 ? rpcDurations.Sum(m => (m.P50 ?? 0) * (m.Count ?? 0)) / totalCount : 0;
    var p99 = totalCount > 0 ? rpcDurations.Sum(m => (m.P99 ?? 0) * (m.Count ?? 0)) / totalCount : 0;

    // Gauges: sum all with same name
    var sessions = metrics.Where(m => m.Name == "auth.active_sessions" && m.Type == "gauge").Sum(m => m.Value);

    string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.#} GB";
    }
}

<div class="flex items-center gap-2 text-on-surface-variant text-xs font-bold mb-1">
    <span class="material-symbols-outlined text-[14px]">dashboard</span>
    <span class="uppercase tracking-widest">Console</span>
</div>
<h2 class="text-3xl font-extrabold text-on-surface tracking-tight mb-8">Dashboard</h2>

<!-- Health Summary -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Databases</div>
        <div class="text-lg font-semibold text-slate-900">@Model.Databases.Count</div>
        <div class="text-xs text-slate-400 mt-1">@FormatSize(Model.Storage.TotalSize) total</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Total Requests</div>
        <div class="text-lg font-semibold text-slate-900">@totalRequests.ToString("N0")</div>
        <div class="text-xs text-slate-400 mt-1">since startup</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Active Sessions</div>
        <div class="text-lg font-semibold text-slate-900">@sessions.ToString("N0")</div>
    </div>
</div>

<!-- Performance -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Error Rate</div>
        <div class="text-lg font-semibold @(errorRate > 5 ? "text-red-600" : errorRate > 1 ? "text-amber-600" : "text-emerald-600")">@errorRate.ToString("0.##")%</div>
        <div class="text-xs text-slate-400 mt-1">@totalErrors.ToString("N0") errors</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Avg Latency (P50)</div>
        <div class="text-lg font-semibold text-slate-900">@p50.ToString("0.#") ms</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">P99 Latency</div>
        <div class="text-lg font-semibold @(p99 > 1000 ? "text-amber-600" : "text-slate-900")">@p99.ToString("0.#") ms</div>
    </div>
</div>

<!-- Two Columns: Exceptions + Databases -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Recent Exceptions -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-bold text-slate-700 uppercase tracking-widest">Recent Exceptions</h3>
            <a href="/@Routes.Prefix/exceptions"
               hx-get="/@Routes.Prefix/exceptions"
               hx-target="#content"
               hx-push-url="true"
               class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">View all</a>
        </div>
        @if (Model.RecentExceptions.Items.Count == 0)
        {
            <div class="bg-white border border-slate-200 rounded-sm p-8 text-center">
                <span class="material-symbols-outlined text-2xl text-emerald-300 mb-2">check_circle</span>
                <div class="text-sm text-slate-500">No recent exceptions</div>
            </div>
        }
        else
        {
            <div class="bg-white border border-slate-200 rounded-sm overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-200 bg-slate-50">
                            <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Exception</th>
                            <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold w-36">Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ex in Model.RecentExceptions.Items)
                        {
                            <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                                <td class="px-4 py-2.5">
                                    <div class="font-mono text-xs text-red-600 font-medium">@ex.ExceptionType</div>
                                    <div class="text-xs text-slate-500 truncate max-w-xs">@ex.Message</div>
                                </td>
                                <td class="px-4 py-2.5 text-right text-xs text-slate-500">@ex.Timestamp.ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Databases -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-bold text-slate-700 uppercase tracking-widest">Databases</h3>
            <a href="/@Routes.Prefix/storage"
               hx-get="/@Routes.Prefix/storage"
               hx-target="#content"
               hx-push-url="true"
               class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">Storage details</a>
        </div>
        @if (Model.Databases.Count == 0)
        {
            <div class="bg-white border border-slate-200 rounded-sm p-8 text-center">
                <span class="material-symbols-outlined text-2xl text-slate-300 mb-2">database</span>
                <div class="text-sm text-slate-500">No databases found</div>
            </div>
        }
        else
        {
            <div class="bg-white border border-slate-200 rounded-sm overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-200 bg-slate-50">
                            <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Database</th>
                            <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Size</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var db in Model.Databases)
                        {
                            <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                                <td class="px-4 py-2.5">
                                    <a href="/@Routes.Prefix/db/@db.Name"
                                       hx-get="/@Routes.Prefix/db/@db.Name"
                                       hx-target="#content"
                                       hx-push-url="true"
                                       class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[16px]">database</span>
                                        @db.Name
                                    </a>
                                </td>
                                <td class="px-4 py-2.5 text-right text-slate-600 font-mono text-sm">@FormatSize(db.Size)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Quick Links -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    @{
        var links = new[] {
            ($"/{Routes.Prefix}/metrics", "monitoring", "Metrics", "Performance counters & latency"),
            ($"/{Routes.Prefix}/traces", "timeline", "Traces", "Distributed request tracing"),
            ($"/{Routes.Prefix}/logs", "receipt_long", "Logs", "System log entries"),
            ($"/{Routes.Prefix}/procedures", "code", "Procedures", "Registered stored procedures")
        };
    }
    @foreach (var (href, icon, label, desc) in links)
    {
        <a href="@href"
           hx-get="@href"
           hx-target="#content"
           hx-push-url="true"
           class="bg-white border border-slate-200 rounded-sm p-4 hover:border-indigo-300 hover:shadow-sm transition-all group">
            <span class="material-symbols-outlined text-[20px] text-slate-400 group-hover:text-indigo-500 mb-2">@icon</span>
            <div class="text-sm font-semibold text-slate-700 group-hover:text-indigo-600">@label</div>
            <div class="text-xs text-slate-400 mt-0.5">@desc</div>
        </a>
    }
</div>
