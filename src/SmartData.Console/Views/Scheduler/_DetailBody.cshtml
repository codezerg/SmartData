@model SchedulerDetailViewModel
@{
    var s = Model.Schedule;
}

<div id="detail-body">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-3xl font-extrabold text-on-surface tracking-tight">@s.Name</h2>
            <div class="mono text-sm text-slate-500 mt-1">@s.ProcedureName</div>
            @if (!string.IsNullOrEmpty(s.Description))
            {
                <div class="text-sm text-slate-600 mt-2">@s.Description</div>
            }
        </div>
        <div class="flex items-center gap-2">
            <button hx-post="/@Routes.Prefix/schedulers/@s.Id/start"
                    hx-target="#detail-body"
                    hx-swap="outerHTML"
                    class="bg-gradient-to-br from-primary to-primary-container text-white px-4 py-1.5 text-sm font-bold rounded-sm shadow-sm flex items-center gap-1 hover:opacity-90">
                <span class="material-symbols-outlined text-[18px]">play_arrow</span>
                Run now
            </button>
            <button hx-post="/@Routes.Prefix/schedulers/@s.Id/cancel"
                    hx-target="#detail-body"
                    hx-swap="outerHTML"
                    hx-confirm="Cancel in-flight runs for this schedule?"
                    class="bg-amber-50 text-amber-700 px-4 py-1.5 text-sm font-bold rounded-sm flex items-center gap-1 hover:bg-amber-100">
                <span class="material-symbols-outlined text-[18px]">stop_circle</span>
                Cancel running
            </button>
            <form hx-post="/@Routes.Prefix/schedulers/@s.Id/toggle-detail"
                  hx-target="#detail-body"
                  hx-swap="outerHTML"
                  class="inline-flex">
                <input type="hidden" name="enabled" value="@((!s.Enabled).ToString().ToLowerInvariant())" />
                @if (s.Enabled)
                {
                    <button type="submit"
                            class="bg-slate-100 text-slate-700 px-4 py-1.5 text-sm font-bold rounded-sm flex items-center gap-1 hover:bg-slate-200">
                        <span class="material-symbols-outlined text-[18px]">toggle_on</span>
                        Disable
                    </button>
                }
                else
                {
                    <button type="submit"
                            class="bg-emerald-50 text-emerald-700 px-4 py-1.5 text-sm font-bold rounded-sm flex items-center gap-1 hover:bg-emerald-100">
                        <span class="material-symbols-outlined text-[18px]">toggle_off</span>
                        Enable
                    </button>
                }
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-2.5 rounded-sm text-sm mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">check_circle</span>
            @Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2.5 rounded-sm text-sm mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">error</span>
            @Model.ErrorMessage
        </div>
    }

    <div class="grid grid-cols-3 gap-4 mb-6">
        <!-- Info -->
        <div class="col-span-2 bg-white border border-outline-variant/20 p-4 rounded-sm">
            <div class="text-xs uppercase tracking-widest font-bold text-slate-400 mb-3">Info</div>
            <dl class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
                <dt class="text-slate-500">Frequency</dt>
                <dd class="font-semibold">@s.FreqType @(s.FreqInterval > 1 ? $"× {s.FreqInterval}" : "") @s.FreqUnit</dd>

                <dt class="text-slate-500">Time of day</dt>
                <dd class="mono">@(s.TimeOfDay?.ToString(@"hh\:mm") ?? "—")</dd>

                <dt class="text-slate-500">Between</dt>
                <dd class="mono">@(s.BetweenStart.HasValue && s.BetweenEnd.HasValue ? $"{s.BetweenStart:hh\\:mm} – {s.BetweenEnd:hh\\:mm}" : "—")</dd>

                <dt class="text-slate-500">Enabled</dt>
                <dd>
                    @if (s.Enabled)
                    {
                        <span class="text-emerald-600 font-semibold">Yes</span>
                    }
                    else
                    {
                        <span class="text-slate-400">No</span>
                    }
                </dd>

                <dt class="text-slate-500">Owner</dt>
                <dd class="mono text-xs">@s.OwnerUser</dd>

                <dt class="text-slate-500">Next run</dt>
                <dd class="mono text-xs">@(s.NextRunOn?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</dd>

                <dt class="text-slate-500">Last run</dt>
                <dd class="mono text-xs">@(s.LastRunOn?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</dd>

                <dt class="text-slate-500">Retry</dt>
                <dd>@s.RetryAttempts attempt(s), @s.RetryIntervalSeconds s interval</dd>

                <dt class="text-slate-500">Jitter</dt>
                <dd>@s.JitterSeconds s</dd>
            </dl>
        </div>

        <!-- Edit retry -->
        <div class="bg-white border border-outline-variant/20 p-4 rounded-sm">
            <div class="text-xs uppercase tracking-widest font-bold text-slate-400 mb-3">Edit retry</div>
            <form hx-post="/@Routes.Prefix/schedulers/@s.Id/edit"
                  hx-target="#detail-body"
                  hx-swap="outerHTML">
                <label class="block text-xs text-slate-500 mb-1">Retry attempts (total, incl. first)</label>
                <input type="number" name="retryAttempts" min="1" value="@s.RetryAttempts"
                       class="w-full bg-white border border-slate-200 px-2 py-1 text-sm rounded-sm mb-3" />
                <label class="block text-xs text-slate-500 mb-1">Retry interval (seconds)</label>
                <input type="number" name="retryIntervalSeconds" min="0" value="@s.RetryIntervalSeconds"
                       class="w-full bg-white border border-slate-200 px-2 py-1 text-sm rounded-sm mb-3" />
                <label class="block text-xs text-slate-500 mb-1">Jitter (seconds)</label>
                <input type="number" name="jitterSeconds" min="0" value="@s.JitterSeconds"
                       class="w-full bg-white border border-slate-200 px-2 py-1 text-sm rounded-sm mb-3" />
                <button type="submit"
                        class="w-full bg-primary text-white px-3 py-1.5 text-sm font-bold rounded-sm hover:opacity-90">
                    Save
                </button>
            </form>
        </div>
    </div>

    <!-- Preview -->
    <div class="bg-white border border-outline-variant/20 p-4 rounded-sm mb-6">
        <div class="text-xs uppercase tracking-widest font-bold text-slate-400 mb-3">Next fires</div>
        @if (Model.Preview.Count == 0)
        {
            <div class="text-sm text-slate-400">No upcoming fires — schedule is exhausted or disabled.</div>
        }
        else
        {
            <div class="flex flex-wrap gap-2">
                @foreach (var t in Model.Preview)
                {
                    <span class="mono text-xs bg-slate-100 text-slate-700 px-2 py-1 rounded-sm">@t.ToString("yyyy-MM-dd HH:mm:ss")</span>
                }
            </div>
        }
    </div>

    <!-- Recent runs -->
    <div class="bg-white border border-outline-variant/20 rounded-sm overflow-hidden">
        <div class="px-4 py-2 border-b border-slate-100 text-xs uppercase tracking-widest font-bold text-slate-400">Recent runs</div>
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-200">
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Started</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Attempt</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Outcome</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Duration</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Instance</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Message</th>
                </tr>
            </thead>
            <tbody>
                @if (s.RecentRuns.Count == 0)
                {
                    <tr><td colspan="6" class="px-3 py-6 text-center text-slate-400 text-sm">No runs yet.</td></tr>
                }
                @foreach (var r in s.RecentRuns)
                {
                    var (bg, fg) = r.Outcome switch
                    {
                        "Succeeded" => ("bg-emerald-50", "text-emerald-600"),
                        "Failed"    => ("bg-red-50", "text-red-600"),
                        "Running"   => ("bg-blue-50", "text-blue-600"),
                        "Claimed"   => ("bg-slate-100", "text-slate-600"),
                        "Cancelled" => ("bg-amber-50", "text-amber-600"),
                        _ => ("", "text-slate-400"),
                    };
                    <tr class="border-b border-slate-100">
                        <td class="px-3 py-2 mono text-xs text-slate-600">@r.StartedOn.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td class="px-3 py-2 text-xs">@r.AttemptNumber</td>
                        <td class="px-3 py-2 text-xs"><span class="@bg @fg inline-flex px-2 py-0.5 rounded-sm font-semibold">@r.Outcome</span></td>
                        <td class="px-3 py-2 mono text-xs text-slate-500">@r.DurationMs ms</td>
                        <td class="px-3 py-2 mono text-xs text-slate-400">@r.InstanceId</td>
                        <td class="px-3 py-2 text-xs text-slate-600">@(r.Message ?? "")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
