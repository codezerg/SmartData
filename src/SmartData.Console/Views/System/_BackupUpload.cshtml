<div class="bg-white border border-slate-200 rounded-sm p-5">
    <div class="text-sm font-semibold text-slate-700 mb-3">Upload Backup</div>

    <!-- File picker (initial state) -->
    <div id="upload-picker">
        <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-slate-300 rounded-sm cursor-pointer hover:border-indigo-400 hover:bg-indigo-50/30 transition-colors">
            <span class="material-symbols-outlined text-3xl text-slate-400 mb-1">cloud_upload</span>
            <span class="text-sm text-slate-500">Click to select a <span class="font-mono font-semibold">.smartbackup</span> file</span>
            <input type="file" accept=".smartbackup" class="hidden" onchange="backupUpload.selectFile(this.files[0])">
        </label>
    </div>

    <!-- Progress (during upload) -->
    <div id="upload-progress" class="hidden">
        <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px] text-indigo-600 animate-pulse" id="upload-icon">cloud_upload</span>
                <span class="text-sm font-medium text-slate-700" id="upload-filename"></span>
            </div>
            <span class="text-xs font-mono text-slate-500" id="upload-stats"></span>
        </div>
        <div class="w-full bg-slate-200 rounded-full h-2 mb-3">
            <div id="upload-bar" class="bg-indigo-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-xs text-slate-500" id="upload-status">Preparing...</span>
            <button onclick="backupUpload.cancel()" id="upload-cancel-btn"
                    class="ml-auto text-xs text-red-500 hover:text-red-700 font-semibold">
                Cancel
            </button>
        </div>
    </div>

    <!-- Result (after upload) -->
    <div id="upload-result" class="hidden"></div>

    <div class="flex items-center gap-2 mt-3">
        <button type="button" onclick="document.getElementById('upload-panel').classList.add('hidden'); backupUpload.reset();"
                class="text-sm text-slate-500 hover:text-slate-700 px-3 py-1.5">
            Close
        </button>
    </div>
</div>
