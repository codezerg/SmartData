@model StorageViewModel
@{
    var storage = Model.Storage;
    var maxDbSize = storage.Databases.Count > 0 ? storage.Databases.Max(d => d.Size) : 1;

    string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.#} GB";
    }
}

<div class="flex items-center gap-2 text-on-surface-variant text-xs font-bold mb-1">
    <span class="material-symbols-outlined text-[14px]">hard_drive</span>
    <span class="uppercase tracking-widest">System</span>
</div>
<h2 class="text-3xl font-extrabold text-on-surface tracking-tight mb-8">Storage</h2>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Database Size</div>
        <div class="text-lg font-semibold text-slate-900">@FormatSize(storage.DbSize)</div>
        <div class="text-xs text-slate-400 mt-1">@storage.Databases.Count database(s)</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Backup Size</div>
        <div class="text-lg font-semibold text-slate-900">@FormatSize(storage.BackupSize)</div>
        <div class="text-xs text-slate-400 mt-1">@storage.Backups.Count backup(s)</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-sm p-5">
        <div class="text-[11px] text-slate-400 uppercase tracking-widest font-bold mb-1">Total Size</div>
        <div class="text-lg font-semibold text-slate-900">@FormatSize(storage.TotalSize)</div>
    </div>
</div>

<!-- Databases Section -->
<h3 class="text-sm font-bold text-slate-700 uppercase tracking-widest mb-3">Databases</h3>
@if (storage.Databases.Count == 0)
{
    <div class="text-center py-12">
        <span class="material-symbols-outlined text-4xl text-slate-300 mb-3">database</span>
        <div class="font-semibold text-slate-600 mb-1">No Databases</div>
        <div class="text-sm text-slate-400">No databases found.</div>
    </div>
}
else
{
    <div class="bg-white border border-slate-200 rounded-sm overflow-hidden mb-8">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-200 bg-slate-50">
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Database</th>
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold w-1/2">Usage</th>
                    <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold w-32">Size</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var db in storage.Databases.OrderByDescending(d => d.Size))
                {
                    var pct = maxDbSize > 0 ? (double)db.Size / maxDbSize * 100 : 0;
                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                        <td class="px-4 py-2.5">
                            <a href="/@Routes.Prefix/db/@db.Name"
                               hx-get="/@Routes.Prefix/db/@db.Name"
                               hx-target="#content"
                               hx-push-url="true"
                               class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">database</span>
                                @db.Name
                            </a>
                        </td>
                        <td class="px-4 py-2.5">
                            <div class="w-full bg-slate-100 rounded-sm h-2">
                                <div class="bg-indigo-500 h-2 rounded-sm" style="width: @pct.ToString("0.#")%"></div>
                            </div>
                        </td>
                        <td class="px-4 py-2.5 text-right text-slate-600 font-mono text-sm">@FormatSize(db.Size)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Backups Section -->
<h3 class="text-sm font-bold text-slate-700 uppercase tracking-widest mb-3">Backups</h3>
@if (storage.Backups.Count == 0)
{
    <div class="text-center py-12">
        <span class="material-symbols-outlined text-4xl text-slate-300 mb-3">backup</span>
        <div class="font-semibold text-slate-600 mb-1">No Backups</div>
        <div class="text-sm text-slate-400">No backups have been created yet.</div>
    </div>
}
else
{
    <div class="bg-white border border-slate-200 rounded-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-200 bg-slate-50">
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Backup ID</th>
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Databases</th>
                    <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold w-32">Size</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var backup in storage.Backups.OrderByDescending(b => b.Size))
                {
                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                        <td class="px-4 py-2.5 font-mono text-sm">@backup.BackupId</td>
                        <td class="px-4 py-2.5">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var db in backup.Databases)
                                {
                                    <span class="inline-flex items-center bg-indigo-50 text-indigo-700 text-xs font-medium px-2 py-0.5 rounded-sm">@db</span>
                                }
                            </div>
                        </td>
                        <td class="px-4 py-2.5 text-right text-slate-600 font-mono text-sm">@FormatSize(backup.Size)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
