@model SystemPageViewModel

<div class="flex items-center gap-2 text-on-surface-variant text-xs font-bold mb-1">
    <span class="material-symbols-outlined text-[14px]">@Model.Icon</span>
    <span class="uppercase tracking-widest">System</span>
</div>
<h2 class="text-3xl font-extrabold text-on-surface tracking-tight mb-8">@Model.Title</h2>
<div class="text-center py-16">
    <span class="material-symbols-outlined text-4xl text-slate-300 mb-3">@Model.PlaceholderIcon</span>
    <div class="font-semibold text-slate-600 mb-1">Coming Soon</div>
    <div class="text-sm text-slate-400">@Model.Description</div>
</div>
