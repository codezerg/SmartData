@model BackupsViewModel
@{
    string FormatSize(long? bytes)
    {
        if (bytes == null) return "-";
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.#} GB";
    }

    string OperationBadge(string op) => op switch
    {
        "create" => "bg-emerald-50 text-emerald-700",
        "restore" => "bg-amber-50 text-amber-700",
        "drop" => "bg-red-50 text-red-700",
        _ => "bg-slate-50 text-slate-700"
    };

    string OperationIcon(string op) => op switch
    {
        "create" => "add_circle",
        "restore" => "settings_backup_restore",
        "drop" => "delete",
        _ => "info"
    };

    string StatusBadge(string status) => status switch
    {
        "success" => "bg-emerald-50 text-emerald-700",
        "failed" => "bg-red-50 text-red-700",
        _ => "bg-slate-50 text-slate-700"
    };
}

@if (Model.History.Count == 0)
{
    <div class="text-center py-16">
        <span class="material-symbols-outlined text-4xl text-slate-300 mb-3">history</span>
        <div class="font-semibold text-slate-600 mb-1">No History</div>
        <div class="text-sm text-slate-400">No backup operations have been recorded yet.</div>
    </div>
}
else
{
    <div class="bg-white border border-slate-200 rounded-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-200 bg-slate-50">
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Operation</th>
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Backup ID</th>
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Databases</th>
                    <th class="text-left px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Status</th>
                    <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Size</th>
                    <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Duration</th>
                    <th class="text-right px-4 py-2.5 text-[11px] text-slate-500 uppercase tracking-widest font-bold">Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.History)
                {
                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                        <td class="px-4 py-2.5">
                            <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-sm @OperationBadge(entry.Operation)">
                                <span class="material-symbols-outlined text-[12px]">@OperationIcon(entry.Operation)</span>
                                @entry.Operation
                            </span>
                        </td>
                        <td class="px-4 py-2.5 font-mono text-sm text-slate-600">@entry.BackupId</td>
                        <td class="px-4 py-2.5">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var db in entry.Databases)
                                {
                                    <span class="inline-flex items-center bg-indigo-50 text-indigo-700 text-xs font-medium px-2 py-0.5 rounded-sm">@db</span>
                                }
                            </div>
                        </td>
                        <td class="px-4 py-2.5">
                            <span class="inline-flex items-center text-xs font-semibold px-2 py-0.5 rounded-sm @StatusBadge(entry.Status)">
                                @entry.Status
                            </span>
                            @if (!string.IsNullOrEmpty(entry.Error))
                            {
                                <div class="text-xs text-red-500 mt-0.5">@entry.Error</div>
                            }
                        </td>
                        <td class="px-4 py-2.5 text-right text-slate-600 font-mono text-sm">@FormatSize(entry.Size)</td>
                        <td class="px-4 py-2.5 text-right text-slate-600 font-mono text-sm">@(entry.DurationMs > 0 ? $"{entry.DurationMs}ms" : "-")</td>
                        <td class="px-4 py-2.5 text-right text-slate-600 text-sm">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
