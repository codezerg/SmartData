@model SearchHit[]
@{
    var q = ViewData["Query"] as string;
}
@if (string.IsNullOrWhiteSpace(q))
{
    // empty — nothing to render (hides the dropdown)
}
else if (Model.Length == 0)
{
    <div class="p-3 text-body-secondary small">No results for "@q".</div>
}
else
{
    <ul class="list-group list-group-flush">
      @foreach (var h in Model)
      {
        <li class="list-group-item">
          <a class="fw-bold text-decoration-none"
             href="/@h.Page.Slug"
             hx-get="/@h.Page.Slug"
             hx-target="#article"
             hx-push-url="true"
             onclick="document.getElementById('search-results').innerHTML=''">@h.Page.Title</a>
          <div class="small text-body-secondary">@h.Snippet</div>
        </li>
      }
    </ul>
}
